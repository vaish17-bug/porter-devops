{
  "info": {
    "name": "Porter Delivery System API",
    "description": "Complete API collection for Mini Porter microservices",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "User Service",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const suffix = Date.now().toString().slice(-6);",
                  "pm.collectionVariables.set('userEmail', `raj.${suffix}@example.com`);",
                  "pm.collectionVariables.set('userPhone', `98${suffix}${suffix}`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.user && response.user.id) { pm.collectionVariables.set('userId', response.user.id); }",
                  "pm.test('register returns 201', function () { pm.response.to.have.status(201); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}:5001/auth/register",
            "header": {
              "Content-Type": "application/json"
            },
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Raj Kumar\", \"email\": \"{{userEmail}}\", \"phone\": \"{{userPhone}}\", \"password\": \"password123\"}"
            }
          }
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.token) { pm.collectionVariables.set('token', response.token); }",
                  "if (response.user && response.user.id) { pm.collectionVariables.set('userId', response.user.id); }",
                  "pm.test('login returns 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}:5001/auth/login",
            "header": {
              "Content-Type": "application/json"
            },
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"{{userEmail}}\", \"password\": \"password123\"}"
            }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}:5001/auth/profile",
            "header": {
              "Authorization": "Bearer {{token}}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('profile returns 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}:5001/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('health returns 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Booking Service",
      "item": [
        {
          "name": "Create Booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.booking && response.booking.bookingId) { pm.collectionVariables.set('bookingId', response.booking.bookingId); }",
                  "pm.test('booking created', function () { pm.response.to.have.status(201); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}:5002/bookings",
            "header": {
              "Authorization": "Bearer {{token}}",
              "Content-Type": "application/json"
            },
            "body": {
              "mode": "raw",
              "raw": "{\"userId\": \"{{userId}}\", \"pickup\": {\"name\": \"Airport\", \"latitude\": 28.5562, \"longitude\": 77.1000}, \"drop\": {\"name\": \"City Center\", \"latitude\": 28.6273, \"longitude\": 77.1854}}"
            }
          }
        },
        {
          "name": "Get Booking",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}:5002/bookings/{{bookingId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('get booking returns 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Get User Bookings",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}:5002/bookings/user/{{userId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('get user bookings returns 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}:5002/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('health returns 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Driver Service",
      "item": [
        {
          "name": "Get All Drivers",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}:5003/drivers"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.drivers && response.drivers.length > 0) { pm.collectionVariables.set('driverId', response.drivers[0].driverId); }",
                  "pm.test('get all drivers returns 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Driver",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const suffix = Date.now().toString().slice(-6);",
                  "pm.collectionVariables.set('driverName', `Priya Singh ${suffix}`);",
                  "pm.collectionVariables.set('driverPhone', `97${suffix}${suffix}`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.driver && response.driver.driverId) { pm.collectionVariables.set('driverId', response.driver.driverId); }",
                  "pm.test('driver created', function () { pm.response.to.have.status(201); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}:5003/drivers",
            "header": {
              "Content-Type": "application/json"
            },
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"{{driverName}}\", \"phone\": \"{{driverPhone}}\", \"vehicleType\": \"auto\"}"
            }
          }
        },
        {
          "name": "Assign Driver",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.driver && response.driver.driverId) { pm.collectionVariables.set('driverId', response.driver.driverId); }",
                  "pm.test('assign driver returns 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}:5003/drivers/assign/{{bookingId}}",
            "header": {
              "Content-Type": "application/json"
            },
            "body": {
              "mode": "raw",
              "raw": "{\"bookingId\": \"{{bookingId}}\", \"pickupLat\": 28.5562, \"pickupLon\": 77.1000}"
            }
          }
        },
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}:5003/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('health returns 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        }
      ]
